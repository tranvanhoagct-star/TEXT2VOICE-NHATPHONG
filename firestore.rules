rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidTrack(data) {
      return data.keys().hasAll(['id', 'userId', 'text', 'voice', 'speed', 'pitch', 'bassBoost', 'audioBase64', 'createdAt'])
        && data.keys().size() == 9
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.userId == request.auth.uid
        && data.text is string && data.text.size() <= 4000
        && data.voice is string && data.voice.size() <= 50
        && (data.speed is number || data.speed is float || data.speed is int)
        && (data.pitch is number || data.pitch is float || data.pitch is int)
        && data.bassBoost is bool
        && data.audioBase64 is string && data.audioBase64.size() <= 1200000
        && data.createdAt is timestamp && data.createdAt == request.time;
    }

    match /tracks/{trackId} {
      allow create: if isSignedIn()
        && isValidId(trackId)
        && trackId == request.resource.data.id
        && isValidTrack(request.resource.data);

      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow update: if false; // Tracks are immutable
    }
  }
}
